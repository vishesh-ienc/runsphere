# ============================================
# RunSphere Frontend — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# --- Internal Services ---
VITE_BACKEND_BASE_URL=http://localhost:5000
VITE_PYTHON_SERVICE_BASE_URL=http://localhost:8000

# --- Mapbox (Maps SDK + Geocoding) ---
# Sign up: https://account.mapbox.com/auth/signup/
# Free tier: 50,000 map loads/month
# This token is used client-side (public token starting with pk.)
VITE_MAPBOX_ACCESS_TOKEN=your_mapbox_public_token_here

# ============================================
# RunSphere Backend — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# Get API keys from the sign-up links below

# --- Server ---
PORT=5000

# --- Database ---
MONGODB_URI=mongodb://localhost:27017/runsphere

# --- Auth ---
JWT_SECRET=your_jwt_secret_here

# --- Internal Services ---
PYTHON_SERVICE_URL=http://localhost:8000

# --- Mapbox (Maps, Geocoding, Directions) ---
# Sign up: https://account.mapbox.com/auth/signup/
# Free tier: 50,000 map loads/month, 100,000 geocoding requests/month
# Dashboard: https://account.mapbox.com/access-tokens/
MAPBOX_ACCESS_TOKEN=your_mapbox_access_token_here

# --- GraphHopper (Routing) ---
# Sign up: https://www.graphhopper.com/dashboard/#/register
# Free tier: 500 credits/day (non-commercial)
# Dashboard: https://graphhopper.com/dashboard/#/api-keys
GRAPHHOPPER_API_KEY=your_graphhopper_api_key_here

# --- OpenWeather (Air Quality + Weather) ---
# Sign up: https://home.openweathermap.org/users/sign_up
# Free tier: 1,000 calls/day, 60 calls/min
# Dashboard: https://home.openweathermap.org/api_keys
# Docs: https://openweathermap.org/api/air-pollution
OPENWEATHER_API_KEY=your_openweather_api_key_here

# --- Open-Elevation (Elevation Data) ---
# No API key required! Completely free and open.
# Public API: https://api.open-elevation.com/api/v1/lookup
# Alternative (Open-Meteo): https://api.open-meteo.com/v1/elevation
# Alternative (Open Topo Data): https://api.opentopodata.org/v1/srtm90m
OPEN_ELEVATION_URL=https://api.open-elevation.com/api/v1/lookup
